# ── Copy this file to server/.env and fill in the values ──────────────────────

# Core
PORT=3001
NODE_ENV=development

# Security — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Google OAuth 2.0
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# The URL of the running frontend (used to redirect after OAuth)
CLIENT_ORIGIN=http://localhost:5173
